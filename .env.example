MINSTACK_HTTP_PORT=8080
MINSTACK_CORS_ORIGIN=http://labkeeper:5173
# Resolves via /etc/hosts → 127.0.0.1 (min-idp container port published on host)
MINSTACK_JWKS_URL=http://min-idp:8081/.well-known/jwks.json
MINSTACK_LOG_LEVEL=info
MINSTACK_LOG_FORMAT=console
# Bind address for Agent mTLS WebSocket (host:port; hostname resolved via /etc/hosts)
LABKEEPER_AGENT_ADDR=labkeeper:8443
# Server DB (min-idp style multi-driver; sqlite for local)
LABKEEPER_DB_DRIVER=sqlite
LABKEEPER_DB_DSN=./data/labkeeper.db
# Required: openssl rand -base64 32
LABKEEPER_MASTER_KEY=
