# Add to /etc/hosts: 127.0.0.1 min-idp labkeeper
# OIDC issuer = min-idp Docker hostname
VITE_OIDC_ISSUER=http://min-idp:8081
# Must match MIN_IDP_BOOTSTRAP_SP_CLIENT_ID on min-idp
VITE_OIDC_CLIENT_ID=default
# Must match MIN_IDP_BOOTSTRAP_SP_REDIRECT_URIS on min-idp
VITE_OIDC_REDIRECT_URI=http://labkeeper:5173/callback
VITE_OIDC_LOGIN_LABEL=Login with SSO
# LabKeeper API on the host
VITE_API_URL=http://labkeeper:8080
